#: src/argus/validators/schema_validators/unexpected_sheets_validator.py:28
msgid "unexpected_sheets_validator.unexpected_sheets"
msgstr "{count} unexpected sheets were found in the dataset. Check to see if these are required to be published/archived. Check output for details."

#: src/argus/validators/schema_validators/unexpected_sheets_validator.py:41
msgid "unexpected_sheets_validator.hidden_sheets"
msgstr "There are {count} hidden sheets in the dataset. Check to see if these should be shown or removed before the dataset is published/archived. Check output for details."

#: src/argus/validators/schema_validators/column_name_validator.py:52
msgid "column_name_validator.labels"
msgstr "{count} sheets had column names that appear to be labels instead of variables. Check the output for details."

#: src/argus/validators/schema_validators/duplicate_sheet_match_validator.py:41
msgid "duplicate_sheet_match_validator.duplicate_sheets"
msgstr "{count} sheets were mapped to the same schema sheet. There should be at most a 1-1 mapping for each sheet."

#: src/argus/validators/schema_validators/mandatory_column_validator.py:79
msgid "mandatory_column_validator.mandatory_columns"
msgstr "{count} excel columns were expected but not found. See output for details."

msgid "mandatory_column_validator.missing_sheets"
msgstr "{count} excel sheets were expected but not found. See output for details."

#: src/argus/validators/schema_validators/missing_sheets_validator.py:56
msgid "missing_sheets_validator.missing_sheets"
msgstr "{count} additional sheets were expected but not found. See the output for details."

#: src/argus/validators/schema_validators/missing_sheets_validator.py:69
msgid "missing_sheets_validator.sampling_info"
msgstr "A sheet for 'sampling_info' is expected when weights are added to the clean data. Add this sheet if required."

#: src/argus/validators/schema_validators/missing_sheets_validator.py:81
msgid "missing_sheets_validator.optional_missing_sheets"
msgstr "{count} optional sheets were not found. Check if these sheets are required or not for this dataset. See the output for details."

#: src/argus/validators/data_validators/cleaning_log_to_clean_validator.py:204
msgid "cleaning_log_to_clean_validator.multiple_changes"
msgstr "{count} Ids had multiple changes for the same question. These were not validated. Check the output for details."

#: src/argus/validators/data_validators/cleaning_log_to_clean_validator.py:232
msgid "cleaning_log_to_clean_validator.same_value"
msgstr "{count} row/s had '{old_value_column}' equal '{new_value_column}'. Check the output for details."

#: src/argus/validators/data_validators/cleaning_log_to_clean_validator.py:281
msgid "cleaning_log_to_clean_validator.missing_questions"
msgstr "There are questions listed in '{cleaning_log_sheet}' that were not found in '{clean_data_sheet}'. See output for details."

#: src/argus/validators/data_validators/cleaning_log_to_clean_validator.py:459
msgid "cleaning_log_to_clean_validator.differences"
msgstr "There were {count} differences found in the '{cleaning_log_sheet}' sheet that were not reflected in the '{clean_data_sheet}' sheet. Check the output for details."

#: src/argus/validators/data_validators/column_data_type_validator.py:217
msgid "column_data_type_validator.numeric_check"
msgstr "{count} non-numeric values were found in '{sheet}' when numeric values were expected. Check the output for details."

#: src/argus/validators/data_validators/column_data_type_validator.py:274
msgid "column_data_type_validator.temporal_check"
msgstr "{count} non-temporal values were found in '{sheet}' when temporal values were expected. Check the output for details."

#: src/argus/validators/data_validators/consent_check_validator.py:155
msgid "consent_check_validator.consent_check"
msgstr "There were {count} row/s in '{sheet}'that did not provide consent. Check the output for details."

#: src/argus/validators/data_validators/cross_sheet_id_check_validator.py:130
msgid "cross_sheet_id_check_validator.id_check"
msgstr "{count} Id values for sheet '{child_sheet}' and column '{child_column}' were not found in sheet '{master_sheet}' column '{master_column}'. Check output for details."

#: src/argus/validators/data_validators/cross_sheet_row_sum_check_validator.py:150
msgid "cross_sheet_row_sum_check_validator.row_sum"
msgstr "Sum of row counts for sheets {child_sheets} does not equal {master_sheet} rows ({count_master}). The difference is {count_diff}."

#: src/argus/validators/data_validators/nan_check_validator.py:147
msgid "nan_check_validator.nan_values"
msgstr "There were {count} possible invalid values found. Check the output for details."

#: src/argus/validators/data_validators/pii_validator.py:135
msgid "pii_validator.pii_data"
msgstr "The sheet '{sheet}' contains possible pii data. Check the output for details."

#: src/argus/validators/data_validators/pii_validator.py:148
msgid "pii_validator.pii_columns"
msgstr "Possible Pii columns were found. Check the output for details."

#: src/argus/validators/data_validators/raw_clean_cleaning_log_validator.py:346
msgid "raw_clean_cleaning_log_validator.cleaning_log_diff"
msgstr "There were {count} differences found in the '{clean_sheet}' sheet that were not reflected in the '{log_sheet}' sheet. Check the output for details."

#: src/argus/validators/data_validators/raw_clean_cleaning_log_validator.py:363
msgid "raw_clean_cleaning_log_validator.diff_no_cleaning_log"
msgstr "There were {count} differences found between the '{clean_sheet}' sheet and the '{raw_sheet}' but no cleaning log was found. Check the output for details."

#: src/argus/validators/data_validators/survey_choices_validator.py:368
msgid "survey_choices_validator.invalid_values"
msgstr "There were {count} values found in the {data_sheet} sheet that were not reflected in the {choices_sheet} sheet. Check the output for details."

#: src/argus/validators/data_validators/unique_column_validator.py:72
msgid "unique_column_validator.non_unique"
msgstr "For column '{column}' in sheet '{sheet}' {count} non unique values were found. This column should contain unique values. Check the output for details."

#: src/argus/validators/schema_helpers.py:25
msgid "schema_helpers.get_schema_id_column"
msgstr "Expected 1 ID column for sheet '{sheet}' but {count} were found."

#: src/argus/validators/schema_helpers.py:64
msgid "schema_helpers.get_schema_process_value"
msgstr "process_values were expected for column '{column}' for process '{process}' but were not found."

#: src/argus/validators/schema_helpers.py:132
msgid "schema_helpers.get_schema_loaded_column"
msgstr "A column for '{column}' in schema sheet '{sheet}' is expected."

#: src/argus/validators/schema_helpers.py:192
msgid "schema_helpers.get_schema_loaded_sheet"
msgstr "A schema sheet for '{sheet}' is expected."

msgid "schema_helpers.missing_items"
msgstr "{count} {item_source} {item_type} were expected but not found. Check the output for details."

#: src/argus/validators/data_helpers.py:30
msgid "data_helpers.get_data_loaded_sheet"
msgstr "An excel sheet for '{sheet}' is expected."

#: src/argus/validators/data_helpers.py:88
msgid "data_helpers.get_data_loaded_column"
msgstr "A column for '{column}' in sheet '{sheet}' is expected."

#: src/argus/validators/data_helpers.py:156
msgid "data_helpers.get_data_sheet_id.no_unique"
msgstr "A unique id column for '{sheet}' is expected but none were found."

#: src/argus/validators/data_helpers.py:166
msgid "data_helpers.get_data_sheet_id.count_invalid"
msgstr "{count} unique columns for schema sheet '{sheet}' and matching excel sheet '{excel_sheet}' was expected."

#: src/argus/validators/data_helpers.py:240
msgid "data_helpers.get_matching_columns"
msgstr "Expected 1 linkable ID column for sheets '{source_sheet}' and '{target_sheet}' but {count} were found."

#: src/argus/validators/data_helpers.py:284
msgid "data_helpers.get_matching_columns_alt"
msgstr "Expected 1 linkable ID column for sheets '{source_sheet}' and '{target_sheet}' but '{source_sheet}' had {source_count} and '{target_sheet}' had {target_count}."

#: src/argus/validators/data_helpers.py:419
msgid "data_helpers.get_id_linking_columns.no_columns"
msgstr "Unable to find possible linkable ID columns for sheet '{source_sheet}' and sheet '{target_sheet}'."

#: src/argus/validators/data_helpers.py:456
msgid "data_helpers.get_id_linking_columns.linked_columns"
msgstr "Column '{source_column}' in sheet '{source_sheet}' was linked to column '{target_column}' in sheet '{target_sheet}'."

#: src/argus/validators/data_helpers.py:510
msgid "data_helpers.check_id_column_overlap"
msgstr "Column '{source_column}' in sheet '{source_sheet}' had an overlap of {overlap} with column '{target_column}' in sheet '{target_sheet}'. A minimum of {min_overlap} is required for these columns to be considered linkable id columns."

#: src/argus/validators/data_helpers.py:543
msgid "data_helpers.check_data_exists"
msgstr "The sheet {sheet} contained no data so the validation rule could not be completed. If this sheet legimately has no rows this error can be ignored."

#: src/argus/orchestrator/validation_pipeline.py:131
msgid "validation_pipeline.calamine_cell_error"
msgstr "Loading of the excel file '{file}' encountered an error. Check that the excel sheets do not contain empty columns without headers: {error}."

#: src/argus/orchestrator/validation_pipeline.py:184
msgid "validation_pipeline.passed"
msgstr "Validator '{name}' passed."

msgid "validation_pipeline.limit_details"
msgstr "(Details limited to {count} records.)"

#: src/argus/loaders/base_excel_loader.py:64
msgid "base_excel_loader.match_excel_columns_to_schema.multiple_literal_matches"
msgstr "The schema sheet '{sheet}' column '{column}' had {count} matches to columns. There should be only 1. Check the schema."

#: src/argus/loaders/base_excel_loader.py:94
msgid "base_excel_loader.match_excel_columns_to_schema.fuzzy_match"
msgstr "The schema sheet '{sheet}' column '{column}' was fuzzy matched with an excel column. If this was an accurate match consider renaming this column in the future. See output for details."

#: src/argus/loaders/base_excel_loader.py:111
msgid "base_excel_loader.match_excel_columns_to_schema.fuzzy_match_miltiple"
msgstr "The schema sheet '{sheet}' column '{column}' was fuzzy matched with {count} excel columns so was not matched as this would cause validation errors. See output for details."

#: src/argus/loaders/base_excel_loader.py:172
msgid "base_excel_loader.match_excel_sheet_to_schema.fuzzy_match"
msgstr "Excel sheet '{excel_sheet}' was fuzzy matched with schema sheet {schema_sheet}. If this was an accurate match consider renaming this excel sheet to {schema_sheet} in the future."

#: src/argus/loaders/base_excel_loader.py:189
msgid "base_excel_loader.match_excel_sheet_to_schema.fuzzy_match_multiple"
msgstr "Excel sheet '{excel_sheet}' was fuzzy matched with {count} schema sheets so was not matched. This will lead to validation errors about excel sheets not being found. See output for details."

msgid "base_excel_loader.match_excel_sheet_to_schema.matching_term"
msgstr "Excel sheet '{excel_sheet}' was matched with schema sheet {schema_sheet} using the matching term {matching_term}."


#: src/argus/loaders/base_excel_loader.py:225
msgid "base_excel_loader.check_duplicate_columns"
msgstr "Excel sheet '{excel_sheet}' has {count} duplicate column names and could not be loaded. Check the output for details."

#: src/argus/loaders/excel_loader.py:166
msgid "excel_loader._load_excel_sheet.sheet_not_found"
msgstr "The schema sheet {sheet} was not found."

#: src/argus/loaders/excel_loader.py:214
msgid "excel_loader.load.multiple_matches"
msgstr "Excel sheet {sheet} was matched with multiple schema sheets. This will lead to validation errors about excel sheets not being found."

#: src/argus/models/dynamic_model.py:158
msgid "dynamic_model.build_validators.CleaningLogToClean"
msgstr "No linked cleaning log data sheet for the sheet '{sheet}' was found so the 'CleaningLogToClean' and 'CrossSheetIdCheck' rules could not be run."

#: src/argus/models/dynamic_model.py:180
msgid "dynamic_model.build_validators.RawToCleanToLog"
msgstr "No linked raw sheet for the sheet '{sheet}' was found so the 'RawToCleanToLog' rule could not be run."

#: src/argus/models/dynamic_model.py:223
msgid "dynamic_model.build_validators.CrossSheetRowSumCheck"
msgstr "No linked sheets for the raw data sheet '{sheet}' was found so the 'CrossSheetRowSumCheck' rule could not be run."

#: src/argus/models/dynamic_model.py:258
msgid "dynamic_model.build_validators.CrossSheetIdCheck"
msgstr "No linked clean sheet for the raw data sheet '{sheet}' was found so the 'CrossSheetIdCheck' rule could not be run."

#: src/argus/models/dynamic_model.py:273
msgid "dynamic_model.build_validators.ConsentCheck"
msgstr "No linked clean sheet for the raw data sheet '{sheet}' was found so the 'ConsentCheck' rule could not be run."

#: src/argus/models/dynamic_model.py:293
msgid "dynamic_model.build_validators.consent"
msgstr "No possible raw_data sheet for 'consent' column was found."

#: src/argus/models/dynamic_model.py:310
msgid "dynamic_model.build_validators.clean_data"
msgstr "No possible sheets for 'clean_data' were found."

#: src/argus/models/dynamic_model.py:320
msgid "dynamic_model.build_validators.raw_data"
msgstr "No possible sheets for 'raw_data' were found."

#: src/argus/models/dynamic_model.py:329
msgid "dynamic_model.build_validators.cleaning_log"
msgstr "No possible sheets for 'cleaning_log' were found."

#: src/argus/models/dynamic_model.py:483
msgid "dynamic_model.match_data.id_columns"
msgstr "Expected one unique ID column for sheet '{sheet}' but {count} were found."

#: src/argus/models/dynamic_model.py:601
msgid "dynamic_model.match_data.clean_data_parents"
msgstr "{count} clean data sheets did not match to a parent. There should only be 1 clean data sheet without a parent."

#: src/argus/models/dynamic_model.py:619
msgid "dynamic_model.match_data.raw_data_parents"
msgstr "{count} raw data sheets did not match to a parent. There should only be 1 raw data sheet without a parent."